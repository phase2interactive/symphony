set shell := ["bash", "-uc"]
set dotenv-load
export PATH := env_var_or_default("HOME", "/root") + "/.local/share/mise/shims:" + env_var_or_default("PATH", "/usr/bin:/bin")
export ELIXIR_ERL_OPTIONS := "+fnu"

mix := "mix"

# List available recipes
default:
    @just --list

# Install dependencies and set up the project
setup:
    {{ mix }} setup

# Fetch dependencies
deps:
    {{ mix }} deps.get

# Compile and build the escript binary
build:
    {{ mix }} build

# Format source files
fmt:
    {{ mix }} format

# Check formatting without modifying files
fmt-check:
    {{ mix }} format --check-formatted

# Run Credo linter
lint:
    {{ mix }} lint

# Run ExUnit tests
test *ARGS:
    {{ mix }} test {{ ARGS }}

# Run tests with coverage report
coverage:
    {{ mix }} test --cover

# Run Dialyzer type checks
dialyzer:
    {{ mix }} deps.get
    {{ mix }} dialyzer --format short

# Run the full CI pipeline
ci: setup build fmt-check lint coverage dialyzer

# Start Symphony with the Phoenix dashboard on a given port (default: 4000)
run port="4000" host="0.0.0.0" workflow="./WORKFLOW.md":
    if ss -tlnp | grep -q ':{{ port }} '; then \
        echo "WARNING: port {{ port }} is already in use. Attempting to free it..."; \
        fuser -k {{ port }}/tcp 2>/dev/null || lsof -ti:{{ port }} | xargs kill 2>/dev/null || true; \
        sleep 1; \
        if ss -tlnp | grep -q ':{{ port }} '; then \
            echo "ERROR: could not free port {{ port }}. Kill the process manually."; \
            exit 1; \
        fi; \
    fi
    ./bin/symphony --i-understand-that-this-will-be-running-without-the-usual-guardrails --port {{ port }} --host {{ host }} {{ workflow }}

# Run Playwright E2E tests
e2e *ARGS:
    npx playwright test {{ ARGS }}

# Run Playwright E2E tests in headed mode (visible browser)
e2e-headed *ARGS:
    npx playwright test --headed {{ ARGS }}

# Open the Playwright UI test runner
e2e-ui:
    npx playwright test --ui

# Install Node dependencies and Playwright browsers
e2e-setup:
    npm install
    npx playwright install chromium
